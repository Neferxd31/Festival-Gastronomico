# Django
SECRET_KEY=cambiar-en-produccion
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost

# Base de datos (Postgres en Railway)
DATABASE_URL=postgresql://user:pass@host:port/dbname

# CORS — separar por comas. Ej: https://mi-frontend.up.railway.app
CORS_ALLOWED_ORIGINS=

# CSRF — separar por comas. Ej: https://mi-frontend.up.railway.app
CSRF_TRUSTED_ORIGINS=

# Google OAuth (mismo client id que el frontend)
GOOGLE_CLIENT_ID=

# Brevo (envío de OTP por email)
BREVO_API_KEY=
