<?xml version="1.0" encoding="UTF-8"?>
<!--
  Esquema de base de datos — Festival Gastronómico
  Basado en: Documento técnico FPDI-001 v2.0
  Incluye HU-14 (Restablecer contraseña) y HU-15 (Estadísticas en tiempo real)
  que NO aparecen en el documento original.
-->
<database name="festival_gastronomico">

  <!-- ============================================================
       TABLA: administrador
       HU relacionadas: HU-02, HU-13, HU-14 (nueva)
       RF relacionados: RF-05, RF-07
       Notas: Login por credenciales (no Google). Soporta reset de contraseña.
  ============================================================ -->
  <table name="administrador">
    <column name="id"                  type="SERIAL"       primaryKey="true"/>
    <column name="nombre"              type="VARCHAR(100)"  nullable="false"/>
    <column name="email"               type="VARCHAR(150)"  nullable="false" unique="true"/>
    <column name="password_hash"       type="VARCHAR(255)"  nullable="false"/>
    <!-- Campos para HU-14: Restablecer contraseña -->
    <column name="token_reset"         type="VARCHAR(255)"  nullable="true"
            description="Token único generado al solicitar reset de contraseña"/>
    <column name="token_reset_expiry"  type="TIMESTAMP"     nullable="true"
            description="Fecha y hora de expiración del token (válido 1 hora)"/>
    <column name="created_at"          type="TIMESTAMP"     nullable="false" default="NOW()"/>
    <column name="updated_at"          type="TIMESTAMP"     nullable="false" default="NOW()"/>
  </table>

  <!-- ============================================================
       TABLA: usuario
       HU relacionadas: HU-06, HU-07, HU-08, HU-09, HU-10, HU-13
       RF relacionados: RF-05, RF-07, RF-08, RF-09, RF-10, RF-12, RF-13
       Notas: Votante. Autenticación OAuth 2.0 con Google.
  ============================================================ -->
  <table name="usuario">
    <column name="id"          type="SERIAL"       primaryKey="true"/>
    <column name="nombre"      type="VARCHAR(150)"  nullable="false"/>
    <column name="email"       type="VARCHAR(150)"  nullable="false" unique="true"/>
    <column name="cedula"      type="VARCHAR(20)"   nullable="true"  unique="true"
            description="Cédula del votante según definición de actores del sistema"/>
    <column name="google_id"   type="VARCHAR(100)"  nullable="true"  unique="true"
            description="ID único retornado por Google OAuth 2.0"/>
    <column name="foto_url"    type="TEXT"          nullable="true"/>
    <column name="created_at"  type="TIMESTAMP"     nullable="false" default="NOW()"/>
  </table>

  <!-- ============================================================
       TABLA: festival
       HU relacionadas: HU-11, HU-12
       RF relacionados: RF-15, RF-16, RF-17
  ============================================================ -->
  <table name="festival">
    <column name="id"                    type="SERIAL"      primaryKey="true"/>
    <column name="nombre"                type="VARCHAR(150)" nullable="false"/>
    <column name="estado"                type="VARCHAR(10)"  nullable="false" default="CERRADO"
            description="ABIERTO o CERRADO — manejado por HU-12"/>
    <column name="fecha_inicio"          type="DATE"         nullable="true"/>
    <column name="fecha_fin"             type="DATE"         nullable="true"
            description="Después de esta fecha el admin puede publicar resultados (HU-11)"/>
    <column name="resultados_publicados" type="BOOLEAN"      nullable="false" default="false"/>
    <column name="created_at"            type="TIMESTAMP"    nullable="false" default="NOW()"/>
    <column name="updated_at"            type="TIMESTAMP"    nullable="false" default="NOW()"/>
  </table>

  <!-- ============================================================
       TABLA: restaurante
       HU relacionadas: HU-01, HU-03, HU-04, HU-05
       RF relacionados: RF-01, RF-02, RF-03, RF-04, RF-06, RF-18, RF-19
  ============================================================ -->
  <table name="restaurante">
    <column name="id"              type="SERIAL"       primaryKey="true"/>
    <column name="festival_id"     type="INTEGER"      nullable="false"
            references="festival(id)" onDelete="CASCADE"/>
    <column name="nombre"          type="VARCHAR(150)"  nullable="false"/>
    <column name="descripcion"     type="TEXT"          nullable="false"/>
    <column name="direccion"       type="VARCHAR(255)"  nullable="false"/>
    <column name="contacto"        type="VARCHAR(100)"  nullable="true"/>
    <column name="redes_sociales"  type="JSONB"         nullable="true"
            description="{ instagram, facebook, tiktok, ... }"/>
    <column name="video_url"       type="TEXT"          nullable="true"
            description="URL de video de Instagram (HU-01)"/>
    <column name="latitud"         type="DECIMAL(9,6)"  nullable="true"/>
    <column name="longitud"        type="DECIMAL(9,6)"  nullable="true"/>
    <column name="habilitado"      type="BOOLEAN"       nullable="false" default="true"/>
    <column name="created_at"      type="TIMESTAMP"     nullable="false" default="NOW()"/>
    <column name="updated_at"      type="TIMESTAMP"     nullable="false" default="NOW()"/>
  </table>

  <!-- ============================================================
       TABLA: plato
       HU relacionadas: HU-03
       RF relacionados: RF-03
  ============================================================ -->
  <table name="plato">
    <column name="id"             type="SERIAL"       primaryKey="true"/>
    <column name="restaurante_id" type="INTEGER"       nullable="false" unique="true"
            references="restaurante(id)" onDelete="CASCADE"/>
    <column name="nombre"         type="VARCHAR(150)"  nullable="false"/>
    <column name="descripcion"    type="TEXT"          nullable="true"/>
    <column name="imagen_url"     type="TEXT"          nullable="true"/>
    <column name="created_at"     type="TIMESTAMP"     nullable="false" default="NOW()"/>
    <column name="updated_at"     type="TIMESTAMP"     nullable="false" default="NOW()"/>
  </table>

  <!-- ============================================================
       TABLA: voto
       HU relacionadas: HU-07, HU-08
       RF relacionados: RF-08, RF-09, RF-10, RF-11
  ============================================================ -->
  <table name="voto">
    <column name="id"             type="SERIAL"    primaryKey="true"/>
    <column name="usuario_id"     type="INTEGER"   nullable="false"
            references="usuario(id)" onDelete="CASCADE"/>
    <column name="restaurante_id" type="INTEGER"   nullable="false"
            references="restaurante(id)" onDelete="CASCADE"/>
    <column name="created_at"     type="TIMESTAMP" nullable="false" default="NOW()"/>
    <uniqueConstraint columns="usuario_id, restaurante_id"
                      name="uq_voto_usuario_restaurante"/>
  </table>

  <!-- ============================================================
       TABLA: comentario
       HU relacionadas: HU-09, HU-10
       RF relacionados: RF-12, RF-13, RF-14
  ============================================================ -->
  <table name="comentario">
    <column name="id"             type="SERIAL"    primaryKey="true"/>
    <column name="usuario_id"     type="INTEGER"   nullable="false"
            references="usuario(id)" onDelete="CASCADE"/>
    <column name="restaurante_id" type="INTEGER"   nullable="false"
            references="restaurante(id)" onDelete="CASCADE"/>
    <column name="contenido"      type="TEXT"      nullable="false"/>
    <column name="created_at"     type="TIMESTAMP" nullable="false" default="NOW()"/>
  </table>

  <!-- ============================================================
       TABLA: resultado
       HU relacionadas: HU-11
       RF relacionados: RF-15, RF-16, RF-19
  ============================================================ -->
  <table name="resultado">
    <column name="id"               type="SERIAL"    primaryKey="true"/>
    <column name="festival_id"      type="INTEGER"   nullable="false"
            references="festival(id)" onDelete="CASCADE"/>
    <column name="restaurante_id"   type="INTEGER"   nullable="false"
            references="restaurante(id)" onDelete="CASCADE"/>
    <column name="posicion"         type="INTEGER"   nullable="false"
            description="1, 2 o 3 — lugar en el podio"/>
    <column name="votos_totales"    type="INTEGER"   nullable="false" default="0"/>
    <column name="fecha_publicacion" type="TIMESTAMP" nullable="false" default="NOW()"/>
    <uniqueConstraint columns="festival_id, posicion"      name="uq_resultado_posicion_festival"/>
    <uniqueConstraint columns="festival_id, restaurante_id" name="uq_resultado_restaurante_festival"/>
  </table>

  <!-- ============================================================
       TABLA: estadistica_snapshot   [NUEVA — HU-15]
       HU relacionadas: HU-15 (nueva — Ver estadísticas en tiempo real para admin)
       Notas: Snapshots periódicos de votos y comentarios por restaurante.
              Permite historial y gráficas de evolución en el panel del admin.
  ============================================================ -->
  <table name="estadistica_snapshot">
    <column name="id"                type="SERIAL"        primaryKey="true"/>
    <column name="festival_id"       type="INTEGER"       nullable="false"
            references="festival(id)" onDelete="CASCADE"/>
    <column name="restaurante_id"    type="INTEGER"       nullable="false"
            references="restaurante(id)" onDelete="CASCADE"/>
    <column name="votos_total"       type="INTEGER"       nullable="false" default="0"/>
    <column name="comentarios_total" type="INTEGER"       nullable="false" default="0"/>
    <column name="porcentaje_votos"  type="DECIMAL(5,2)"  nullable="true"
            description="% de votos de este restaurante sobre el total del festival"/>
    <column name="timestamp"         type="TIMESTAMP"     nullable="false" default="NOW()"/>
  </table>

  <!--
  ================================================================
  HU-14 — Restablecer contraseña (Admin) [NUEVA]
  ================================================================
  Actor: Administrador
  Descripción: Como administrador, quiero restablecer mi contraseña
    en caso de olvidarla, para recuperar el acceso al panel de administración.

  Criterios de aceptación:
    Escenario 1: Solicitud de restablecimiento
      Dado que el administrador olvidó su contraseña
      Cuando ingresa su email en el formulario de recuperación
      Entonces el sistema genera un token único, lo guarda en
      administrador.token_reset con expiración de 1 hora, y envía
      un email con el enlace de restablecimiento.
    Escenario 2: Uso del enlace
      Dado que el administrador recibió el email
      Cuando accede al enlace y el token no ha expirado
      Entonces puede ingresar una nueva contraseña y se actualiza
      administrador.password_hash.
    Escenario 3: Token expirado
      Dado que el enlace ya expiró
      Entonces el sistema muestra error y solicita generar uno nuevo.
    Escenario 4: Email no registrado
      Entonces el sistema responde de forma genérica (no revela si existe).

  Campos usados: administrador.token_reset, administrador.token_reset_expiry
  ================================================================

  HU-15 — Ver estadísticas en tiempo real (Admin) [NUEVA]
  ================================================================
  Actor: Administrador
  Descripción: Como administrador, quiero ver las estadísticas de votos
    y comentarios de todos los restaurantes en tiempo real durante el festival.

  Criterios de aceptación:
    Escenario 1: Ranking en tiempo real
      El admin ve todos los restaurantes ordenados por votos (mayor a menor),
      actualizados sin recargar la página (polling o WebSocket).
    Escenario 2: Porcentaje de participación
      El sistema muestra el % de votos de cada restaurante sobre el total.
    Escenario 3: Total de comentarios por restaurante
      El admin ve el número de comentarios de cada restaurante.
    Escenario 4: Actualización automática
      Cuando se registra un nuevo voto o comentario, las estadísticas
      se actualizan automáticamente.
    Escenario 5: Historial de evolución
      El admin puede ver una gráfica de votos a lo largo del tiempo
      usando los datos de estadistica_snapshot.

  Tablas usadas: voto, comentario, restaurante, estadistica_snapshot
  ================================================================
  -->

</database>
